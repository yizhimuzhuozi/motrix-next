{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "motrix-next",
  "identifier": "com.motrix.next",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Motrix Next",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 540,
        "transparent": true,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/aria2c"
    ],
    "resources": [
      "binaries/aria2.conf"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "torrent"
        ],
        "name": "BitTorrent",
        "mimeType": "application/x-bittorrent",
        "description": "BitTorrent File",
        "role": "Viewer"
      },
      {
        "ext": [
          "metalink",
          "meta4"
        ],
        "name": "Metalink",
        "mimeType": "application/metalink+xml",
        "description": "Metalink File",
        "role": "Viewer"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/AnInsomniacy/motrix-next/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2MjEwNDUzQTk3OUM2NDUKUldSRnhubXBVd1FoZHUxeWtoRGJFblZaZ3V3UWZMQTYwL29CQTNySWxQMForTDA2YjN1Mk50Sk4K"
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "magnet",
          "thunder"
        ]
      }
    }
  }
}